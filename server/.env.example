# Copy this file to .env and fill in your values
NODE_ENV=development
PORT=3001
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/railpulse
# MongoDB Atlas (production):
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/railpulse?appName=Cluster0
SBB_API_BASE_URL=https://transport.opendata.ch/v1
CLIENT_URL=http://localhost:3000

# How often the delay tracker polls the SBB API (milliseconds)
# Default: 120000 = 2 minutes
POLLING_INTERVAL_MS=120000
